# Copiar este archivo como .env y completar con los valores reales.
# NUNCA commitear el archivo .env real al repositorio.

# --- Credenciales (obligatorio) ---
GEMINI_API_KEY=

# --- Credenciales (opcional; sin esto se omite la consulta a Asana) ---
ASANA_ACCESS_TOKEN=

# --- Modelos Gemini a usar (opcional, tienen default) ---
GEMINI_MODEL_JSON=gemini-flash-latest

# --- Rutas (opcional, todas relativas a INFORMES_IA_BASE_DIR) ---
INFORMES_IA_BASE_DIR=.
DB_FILENAME=lab_monitor.db
CACHE_FILENAME=docs_cache.json
DOCS_DIRNAME=docs
REPORTES_DIRNAME=reportes
